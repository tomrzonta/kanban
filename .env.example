# Configuração para acesso pela REDE LOCAL (uso de teste).
#
# Para usar: copie este arquivo para ".env" (na mesma pasta do docker-compose.yml),
# troque SEU_IP pelo IP do seu notebook (descubra com `ipconfig`), e suba o projeto.
# Sem este arquivo, o sistema roda normalmente em localhost.

# IP do notebook-servidor, visto pelos outros computadores da rede.
VITE_API_URL=http://SEU_IP:8000

# Libera o acesso de qualquer máquina da rede (ok para teste interno).
CORS_ABERTO=true
